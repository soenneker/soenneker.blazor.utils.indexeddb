@page "/"
@using System.Text.Json
@using System.Threading.Tasks
@using Soenneker.Blazor.Utils.IndexedDb.Abstract

@inject IIndexedDbUtil IndexedDb

<PageTitle>IndexedDb Demo</PageTitle>

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Database" Description="Provisioned store and sample metadata.">
        <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is4">
            <Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Status</Paragraph>
                <Paragraph Margin="Margin.Is0">@(IsReady ? "Ready" : "Initializing")</Paragraph>
            </Div>
            <Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Database</Paragraph>
                <Paragraph Margin="Margin.Is0" FontWeight="FontWeight.Semibold">@DatabaseName</Paragraph>
            </Div>
            <Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Store</Paragraph>
                <Paragraph Margin="Margin.Is0" FontWeight="FontWeight.Semibold">@StoreName</Paragraph>
            </Div>
            <Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Entries</Paragraph>
                <Paragraph Margin="Margin.Is0" FontWeight="FontWeight.Semibold">@_entryCount</Paragraph>
            </Div>
        </Div>
        <DemoButtonRow>
            <Button OnClick="ResetSampleAsync" Disabled="@_busy">Reset sample</Button>
            <Button OnClick="RefreshSnapshotAsync" Variant="ButtonVariant.Outline" Disabled="@_busy">Refresh snapshot</Button>
        </DemoButtonRow>
    </DemoPanel>

    <Grid Columns="Columns.Is1.OnLg.Is2" Gap="Gap.Is4">
        <DemoPanel Title="Playground" Description="Typed DashboardPreference CRUD.">
            <Field>
                <FieldLabel For="idb-key">Record key</FieldLabel>
                <FieldBody>
                    <Input Id="idb-key" @bind-Value="_recordKey" />
                </FieldBody>
            </Field>
            <Field>
                <FieldLabel For="idb-theme">Theme</FieldLabel>
                <FieldBody>
                    <Select Id="idb-theme" TValue="string" @bind-SelectedValue="_draft.Theme">
                        <SelectItem TValue="string" ItemValue="@("System")" Text="System" />
                        <SelectItem TValue="string" ItemValue="@("Light")" Text="Light" />
                        <SelectItem TValue="string" ItemValue="@("Dark")" Text="Dark" />
                    </Select>
                </FieldBody>
            </Field>
            <Field>
                <FieldLabel For="idb-pagesize">Page size</FieldLabel>
                <FieldBody>
                    <Input Id="idb-pagesize" Type="number" Min="10" Max="100" Step="5" @bind-Value="_pageSizeText" />
                </FieldBody>
            </Field>
            <Field>
                <FieldLabel For="idb-compact">Compact mode</FieldLabel>
                <FieldBody>
                    <InputCheckbox @bind-Value="_draft.CompactMode" Id="idb-compact" />
                </FieldBody>
            </Field>
            <Field>
                <FieldLabel For="idb-insights">Show insights</FieldLabel>
                <FieldBody>
                    <InputCheckbox @bind-Value="_draft.ShowInsights" Id="idb-insights" />
                </FieldBody>
            </Field>
            <DemoButtonRow>
                <Button OnClick="SavePreferenceAsync" Disabled="@_busy">Save</Button>
                <Button OnClick="LoadPreferenceAsync" Variant="ButtonVariant.Secondary" Disabled="@_busy">Load</Button>
                <Button OnClick="RemovePreferenceAsync" Variant="ButtonVariant.Outline" Disabled="@_busy">Remove</Button>
                <Button OnClick="ClearStoreAsync" Variant="ButtonVariant.Destructive" Disabled="@_busy">Clear store</Button>
            </DemoButtonRow>
            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">
                <Strong>@_statusTitle</Strong> — @_statusMessage
            </Paragraph>
        </DemoPanel>

        <DemoPanel Title="Loaded record" Description="Deserialized preference and raw JSON.">
            @if (_loadedPreference is null)
            {
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">No record loaded.</Paragraph>
            }
            else
            {
                <Div Space="Space.Y.Is2">
                    <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Theme: <Strong>@_loadedPreference.Theme</Strong></Paragraph>
                    <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Page size: <Strong>@_loadedPreference.PageSize</Strong></Paragraph>
                    <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Compact: <Strong>@(_loadedPreference.CompactMode ? "Yes" : "No")</Strong></Paragraph>
                    <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Insights: <Strong>@(_loadedPreference.ShowInsights ? "Yes" : "No")</Strong></Paragraph>
                </Div>
                @if (!string.IsNullOrEmpty(_loadedPreferenceJson))
                {
                    <PreCode Class="demo-pre" Highlight="false">@_loadedPreferenceJson</PreCode>
                }
            }
        </DemoPanel>
    </Grid>

    <Grid Columns="Columns.Is1.OnLg.Is2" Gap="Gap.Is4">
        <DemoPanel Title="Store snapshot" Description="Keys, counts, and contains checks.">
            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Contains active key: <Strong>@(_containsCurrentKey ? "true" : "false")</Strong></Paragraph>
            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Total entries: <Strong>@_entryCount</Strong></Paragraph>
            <DemoButtonRow>
                <Button OnClick="RefreshSnapshotAsync" Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Disabled="@_busy">Refresh keys</Button>
            </DemoButtonRow>
            @if (_keys.Count == 0)
            {
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Store is empty.</Paragraph>
            }
            else
            {
                <Div Space="Space.Y.Is2">
                    @foreach (string key in _keys)
                    {
                        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">
                            @key
                            @if (key == _recordKey)
                            {
                                <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground"> (active)</Span>
                            }
                        </Paragraph>
                    }
                </Div>
            }
        </DemoPanel>

        <DemoPanel Title="Flow" Description="How this page uses the utility.">
            <Div Space="Space.Y.Is2">
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">1. Initialize and ensure the object store exists.</Paragraph>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">2. Persist a typed model with Set&lt;T&gt;.</Paragraph>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">3. Read back with Get&lt;T&gt; and refresh metadata.</Paragraph>
            </Div>
        </DemoPanel>
    </Grid>
</Div>

@code {
    private const string DatabaseName = "soenneker-indexeddb-demo";
    private const string StoreName = "dashboard-preferences";

    private static readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true
    };

    private readonly List<string> _keys = [];

    private DashboardPreference _draft = DashboardPreference.CreateDefault();
    private DashboardPreference? _loadedPreference;
    private string _recordKey = "jake";
    private string _loadedPreferenceJson = "";
    private string _statusTitle = "Preparing demo";
    private string _statusMessage = "Initializing the IndexedDB showcase...";
    private int _entryCount;
    private bool _containsCurrentKey;
    private bool _busy = true;
    private bool _ready;

    private string _pageSizeText = "25";

    private bool IsReady => _ready && !_busy;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await RunBusyActionAsync("Initializing demo", "Preparing IndexedDB and seeding the showcase store...", async () =>
        {
            await IndexedDb.Initialize();
            await IndexedDb.EnsureStore(DatabaseName, StoreName);

            _ready = true;

            bool hasSeed = await IndexedDb.ContainsKey(DatabaseName, StoreName, _recordKey);

            if (!hasSeed)
            {
                await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);
            }

            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });

        _pageSizeText = _draft.PageSize.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SavePreferenceAsync()
    {
        if (int.TryParse(_pageSizeText, out int ps))
            _draft.PageSize = Math.Clamp(ps, 10, 100);

        await RunBusyActionAsync("Saved preference", $"Stored '{_recordKey}' in IndexedDB.", async () =>
        {
            await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task LoadPreferenceAsync()
    {
        await RunBusyActionAsync("Loaded preference", $"Loaded '{_recordKey}' from IndexedDB.", async () =>
        {
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RemovePreferenceAsync()
    {
        await RunBusyActionAsync("Removed preference", $"Deleted '{_recordKey}' from IndexedDB.", async () =>
        {
            await IndexedDb.Remove(DatabaseName, StoreName, _recordKey);
            _loadedPreference = null;
            _loadedPreferenceJson = "";
            await RefreshSnapshotInternalAsync(loadCurrentRecord: false);
        });
    }

    private async Task ClearStoreAsync()
    {
        await RunBusyActionAsync("Cleared store", "Removed all entries from the showcase store.", async () =>
        {
            await IndexedDb.Clear(DatabaseName, StoreName);
            _loadedPreference = null;
            _loadedPreferenceJson = "";
            await RefreshSnapshotInternalAsync(loadCurrentRecord: false);
        });
    }

    private async Task ResetSampleAsync()
    {
        await RunBusyActionAsync("Reset sample", "Rebuilt the showcase sample data.", async () =>
        {
            _draft = DashboardPreference.CreateDefault();
            _recordKey = "jake";
            _pageSizeText = _draft.PageSize.ToString();

            await IndexedDb.DeleteDatabase(DatabaseName);
            await IndexedDb.EnsureStore(DatabaseName, StoreName);
            await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);

            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RefreshSnapshotAsync()
    {
        await RunBusyActionAsync("Snapshot refreshed", "Reloaded current store metadata and active record.", async () =>
        {
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RefreshSnapshotInternalAsync(bool loadCurrentRecord)
    {
        _containsCurrentKey = await IndexedDb.ContainsKey(DatabaseName, StoreName, _recordKey);
        _entryCount = await IndexedDb.GetLength(DatabaseName, StoreName);

        _keys.Clear();
        _keys.AddRange(await IndexedDb.GetKeys(DatabaseName, StoreName));

        if (!loadCurrentRecord)
            return;

        _loadedPreference = await IndexedDb.Get<DashboardPreference>(DatabaseName, StoreName, _recordKey);
        _loadedPreferenceJson = _loadedPreference is null
            ? ""
            : JsonSerializer.Serialize(_loadedPreference, _jsonOptions);
        if (_loadedPreference != null)
            _pageSizeText = _loadedPreference.PageSize.ToString();
    }

    private async Task RunBusyActionAsync(string successTitle, string successMessage, Func<Task> action)
    {
        _busy = true;

        try
        {
            await action();
            _statusTitle = successTitle;
            _statusMessage = successMessage;
        }
        catch (Exception ex)
        {
            _statusTitle = "Action failed";
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class DashboardPreference
    {
        public string Theme { get; set; } = "Dark";
        public int PageSize { get; set; } = 25;
        public bool CompactMode { get; set; } = true;
        public bool ShowInsights { get; set; } = true;

        public static DashboardPreference CreateDefault()
        {
            return new DashboardPreference();
        }
    }
}
