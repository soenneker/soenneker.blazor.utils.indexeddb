@page "/"
@using System.Text.Json
@using System.Threading.Tasks
@using Soenneker.Blazor.Utils.IndexedDb.Abstract

@inject IIndexedDbUtil IndexedDb

<PageTitle>IndexedDb Demo</PageTitle>

<div class="showcase-page">
    <section class="hero-card">
        <div class="hero-copy">
            <span class="eyebrow">Soenneker.Blazor.Utils.IndexedDb</span>
            <h1>Professional IndexedDB access for Blazor apps</h1>
            <p class="hero-lead">
                This demo showcases the library as a production-ready browser persistence layer with typed serialization,
                store provisioning, CRUD operations, and live inspection of the current object store.
            </p>

            <div class="hero-actions">
                <button class="btn btn-primary btn-lg" @onclick="ResetSampleAsync" disabled="@_busy">Reset sample data</button>
                <button class="btn btn-outline-light btn-lg" @onclick="RefreshSnapshotAsync" disabled="@_busy">Refresh snapshot</button>
            </div>
        </div>

        <div class="hero-panel">
            <div class="status-pill @(IsReady ? "is-ready" : "is-pending")">
                <span class="status-dot"></span>
                @(IsReady ? "Ready" : "Initializing")
            </div>

            <dl class="metric-grid">
                <div class="metric-card">
                    <dt>Database</dt>
                    <dd>@DatabaseName</dd>
                </div>
                <div class="metric-card">
                    <dt>Store</dt>
                    <dd>@StoreName</dd>
                </div>
                <div class="metric-card">
                    <dt>Entries</dt>
                    <dd>@_entryCount</dd>
                </div>
                <div class="metric-card">
                    <dt>Active key</dt>
                    <dd>@_recordKey</dd>
                </div>
            </dl>

            <div class="code-sample">
<pre><code>await indexedDb.Initialize();
await indexedDb.EnsureStore("@DatabaseName", "@StoreName");
await indexedDb.Set("@DatabaseName", "@StoreName", key, payload);
var item = await indexedDb.Get&lt;DashboardPreference&gt;("@DatabaseName", "@StoreName", key);</code></pre>
            </div>
        </div>
    </section>

    <section class="feature-grid">
        <article class="feature-card">
            <h2>Typed object storage</h2>
            <p>Use `Set&lt;T&gt;()` and `Get&lt;T&gt;()` to persist structured models with JSON serialization handled in the utility layer.</p>
        </article>
        <article class="feature-card">
            <h2>Safe store provisioning</h2>
            <p>`EnsureStore()` creates the backing object store when needed, so consumers can provision browser storage explicitly.</p>
        </article>
        <article class="feature-card">
            <h2>Store introspection</h2>
            <p>The demo also exercises `GetKeys()`, `GetLength()`, `ContainsKey()`, `Remove()`, and `Clear()` for operational visibility.</p>
        </article>
    </section>

    <section class="workspace-grid">
        <article class="panel-card">
            <div class="panel-header">
                <div>
                    <span class="panel-label">Live playground</span>
                    <h2>Save a dashboard preference</h2>
                </div>
                <span class="text-badge">Typed demo model</span>
            </div>

            <div class="form-grid">
                <div>
                    <label class="form-label" for="record-key">Record key</label>
                    <input id="record-key" class="form-control form-control-lg" @bind="_recordKey" />
                </div>

                <div>
                    <label class="form-label" for="theme">Theme</label>
                    <select id="theme" class="form-select form-select-lg" @bind="_draft.Theme">
                        <option value="System">System</option>
                        <option value="Light">Light</option>
                        <option value="Dark">Dark</option>
                    </select>
                </div>

                <div>
                    <label class="form-label" for="page-size">Page size</label>
                    <input id="page-size" type="number" min="10" max="100" step="5" class="form-control form-control-lg" @bind="_draft.PageSize" />
                </div>

                <div class="checkbox-row">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_draft.CompactMode" />
                        <span class="form-check-label">Compact mode</span>
                    </label>
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_draft.ShowInsights" />
                        <span class="form-check-label">Show insights</span>
                    </label>
                </div>
            </div>

            <div class="action-row">
                <button class="btn btn-primary" @onclick="SavePreferenceAsync" disabled="@_busy">Save</button>
                <button class="btn btn-outline-secondary" @onclick="LoadPreferenceAsync" disabled="@_busy">Load</button>
                <button class="btn btn-outline-danger" @onclick="RemovePreferenceAsync" disabled="@_busy">Remove</button>
                <button class="btn btn-outline-light" @onclick="ClearStoreAsync" disabled="@_busy">Clear store</button>
            </div>

            <div class="feedback-banner @(_lastActionSucceeded ? "feedback-success" : "feedback-neutral")">
                <strong>@_statusTitle</strong>
                <span>@_statusMessage</span>
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-header">
                <div>
                    <span class="panel-label">Current object</span>
                    <h2>Loaded preference</h2>
                </div>
                <span class="text-badge">From IndexedDB</span>
            </div>

            @if (_loadedPreference is null)
            {
                <div class="empty-state">
                    <p>No record loaded yet. Save or load a record to inspect the deserialized object.</p>
                </div>
            }
            else
            {
                <div class="loaded-grid">
                    <div class="loaded-item">
                        <span>Theme</span>
                        <strong>@_loadedPreference.Theme</strong>
                    </div>
                    <div class="loaded-item">
                        <span>Page size</span>
                        <strong>@_loadedPreference.PageSize</strong>
                    </div>
                    <div class="loaded-item">
                        <span>Compact mode</span>
                        <strong>@(_loadedPreference.CompactMode ? "Enabled" : "Disabled")</strong>
                    </div>
                    <div class="loaded-item">
                        <span>Insights</span>
                        <strong>@(_loadedPreference.ShowInsights ? "Visible" : "Hidden")</strong>
                    </div>
                </div>

                <div class="json-view">
                    <pre>@_loadedPreferenceJson</pre>
                </div>
            }
        </article>
    </section>

    <section class="workspace-grid">
        <article class="panel-card">
            <div class="panel-header">
                <div>
                    <span class="panel-label">Store snapshot</span>
                    <h2>Operational metadata</h2>
                </div>
                <span class="text-badge">`ContainsKey`, `GetKeys`, `GetLength`</span>
            </div>

            <div class="snapshot-grid">
                <div class="snapshot-card">
                    <span>Contains active key</span>
                    <strong>@(_containsCurrentKey ? "True" : "False")</strong>
                </div>
                <div class="snapshot-card">
                    <span>Total entries</span>
                    <strong>@_entryCount</strong>
                </div>
            </div>

            <div class="keys-list">
                <div class="keys-header">
                    <h3>Keys in store</h3>
                    <button class="btn btn-sm btn-outline-light" @onclick="RefreshSnapshotAsync" disabled="@_busy">Refresh</button>
                </div>

                @if (_keys.Count == 0)
                {
                    <div class="empty-state">
                        <p>The store is currently empty.</p>
                    </div>
                }
                else
                {
                    <ul>
                        @foreach (string key in _keys)
                        {
                            <li>
                                <span>@key</span>
                                @if (key == _recordKey)
                                {
                                    <span class="list-badge">Active</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-header">
                <div>
                    <span class="panel-label">Integration summary</span>
                    <h2>How the demo uses the library</h2>
                </div>
                <span class="text-badge">Blazor + IndexedDB</span>
            </div>

            <ol class="summary-list">
                <li>The page initializes the library and provisions a named store.</li>
                <li>Form values are persisted as a typed `DashboardPreference` object.</li>
                <li>Reads are deserialized through `Get&lt;T&gt;()` and rendered back into the UI.</li>
                <li>Store metadata is refreshed using key enumeration and count APIs.</li>
            </ol>
        </article>
    </section>
</div>

@code {
    private const string DatabaseName = "soenneker-indexeddb-demo";
    private const string StoreName = "dashboard-preferences";

    private static readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true
    };

    private readonly List<string> _keys = [];

    private DashboardPreference _draft = DashboardPreference.CreateDefault();
    private DashboardPreference? _loadedPreference;
    private string _recordKey = "jake";
    private string _loadedPreferenceJson = "";
    private string _statusTitle = "Preparing demo";
    private string _statusMessage = "Initializing the IndexedDB showcase...";
    private int _entryCount;
    private bool _containsCurrentKey;
    private bool _busy = true;
    private bool _ready;
    private bool _lastActionSucceeded = true;

    private bool IsReady => _ready && !_busy;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await RunBusyActionAsync("Initializing demo", "Preparing IndexedDB and seeding the showcase store...", async () =>
        {
            await IndexedDb.Initialize();
            await IndexedDb.EnsureStore(DatabaseName, StoreName);

            _ready = true;

            bool hasSeed = await IndexedDb.ContainsKey(DatabaseName, StoreName, _recordKey);

            if (!hasSeed)
            {
                await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);
            }

            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });

        StateHasChanged();
    }

    private async Task SavePreferenceAsync()
    {
        await RunBusyActionAsync("Saved preference", $"Stored '{_recordKey}' in IndexedDB.", async () =>
        {
            await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task LoadPreferenceAsync()
    {
        await RunBusyActionAsync("Loaded preference", $"Loaded '{_recordKey}' from IndexedDB.", async () =>
        {
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RemovePreferenceAsync()
    {
        await RunBusyActionAsync("Removed preference", $"Deleted '{_recordKey}' from IndexedDB.", async () =>
        {
            await IndexedDb.Remove(DatabaseName, StoreName, _recordKey);
            _loadedPreference = null;
            _loadedPreferenceJson = "";
            await RefreshSnapshotInternalAsync(loadCurrentRecord: false);
        });
    }

    private async Task ClearStoreAsync()
    {
        await RunBusyActionAsync("Cleared store", "Removed all entries from the showcase store.", async () =>
        {
            await IndexedDb.Clear(DatabaseName, StoreName);
            _loadedPreference = null;
            _loadedPreferenceJson = "";
            await RefreshSnapshotInternalAsync(loadCurrentRecord: false);
        });
    }

    private async Task ResetSampleAsync()
    {
        await RunBusyActionAsync("Reset sample", "Rebuilt the showcase sample data.", async () =>
        {
            _draft = DashboardPreference.CreateDefault();
            _recordKey = "jake";

            await IndexedDb.DeleteDatabase(DatabaseName);
            await IndexedDb.EnsureStore(DatabaseName, StoreName);
            await IndexedDb.Set(DatabaseName, StoreName, _recordKey, _draft);

            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RefreshSnapshotAsync()
    {
        await RunBusyActionAsync("Snapshot refreshed", "Reloaded current store metadata and active record.", async () =>
        {
            await RefreshSnapshotInternalAsync(loadCurrentRecord: true);
        });
    }

    private async Task RefreshSnapshotInternalAsync(bool loadCurrentRecord)
    {
        _containsCurrentKey = await IndexedDb.ContainsKey(DatabaseName, StoreName, _recordKey);
        _entryCount = await IndexedDb.GetLength(DatabaseName, StoreName);

        _keys.Clear();
        _keys.AddRange(await IndexedDb.GetKeys(DatabaseName, StoreName));

        if (!loadCurrentRecord)
            return;

        _loadedPreference = await IndexedDb.Get<DashboardPreference>(DatabaseName, StoreName, _recordKey);
        _loadedPreferenceJson = _loadedPreference is null
            ? ""
            : JsonSerializer.Serialize(_loadedPreference, _jsonOptions);
    }

    private async Task RunBusyActionAsync(string successTitle, string successMessage, Func<Task> action)
    {
        _busy = true;
        _lastActionSucceeded = true;

        try
        {
            await action();
            _statusTitle = successTitle;
            _statusMessage = successMessage;
        }
        catch (Exception ex)
        {
            _lastActionSucceeded = false;
            _statusTitle = "Action failed";
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class DashboardPreference
    {
        public string Theme { get; set; } = "Dark";
        public int PageSize { get; set; } = 25;
        public bool CompactMode { get; set; } = true;
        public bool ShowInsights { get; set; } = true;

        public static DashboardPreference CreateDefault()
        {
            return new DashboardPreference();
        }
    }
}
